# Copy to keystore.properties and fill in your values (keystore.properties is gitignored).
#
# Create the keystore once:
#   keytool -genkey -v \
#     -keystore garage-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias upload
#
# Passwords are NOT prompted during Gradle builds. Either:
#   1. Put the real passwords below, or
#   2. Run: ./scripts/build-release-aab.sh --prompt
#   3. Or:  KEYSTORE_PASSWORD=... KEY_PASSWORD=... ./scripts/build-release-aab.sh
#
# If keytool asked for a key password and you pressed Enter, both passwords are the same.
#
storeFile=garage-upload.jks
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password
